{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DocTrail",
  "version": "0.1.0",
  "identifier": "com.doctrail.viewer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DocTrail",
        "width": 1180,
        "height": 820,
        "minWidth": 820,
        "minHeight": 560,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "category": "Productivity",
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd"],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Viewer",
        "mimeType": "text/markdown",
        "rank": "Default",
        "contentTypes": ["net.daringfireball.markdown", "public.plain-text"]
      }
    ]
  }
}
